# ============================================
# SwachhVan Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Supabase (Frontend - Vite) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Supabase (Backend - Python scripts) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- RAG AI Chatbot Server ---
VITE_RAG_URL=http://localhost:8091

# --- Geocode / Location Search ---
VITE_GEOCODE_URL=http://localhost:8091

# --- SerpAPI (Google Maps Geocoding) ---
# Get a free key at https://serpapi.com
SERPAPI_KEY=your-serpapi-key-here

# --- Demo Auth Mode ---
VITE_DEMO_AUTH=true
